            <label class="chip"><input type="checkbox" value="Comunicação e alinhamento"> Comunicação</label>
            <label class="chip"><input type="checkbox" value="Análise de dados"> Análise de dados</label>
            <label class="chip"><input type="checkbox" value="Ferramentas de gestão"> Ferramentas</label>
