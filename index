<div class="fab" onclick="openAdmin()" title="Painel administrativo">🔒</div>

<div id="overlay" class="overlay" onclick="overlayClick(event)">
  <div class="admin-sheet">
    <div class="admin-head">
      <h3>🔐 Painel Administrativo</h3>
      <div class="x-btn" onclick="closeAdmin()">✕</div>
    </div>
    <div class="admin-body">
      <div id="authSection">
        <p class="auth-desc">Digite a senha de acesso para visualizar as respostas coletadas.</p>
        <div class="auth-row">
          <input type="password" id="adminPwd" placeholder="Senha" onkeyup="if(event.key==='Enter')verifyPwd()">
          <button onclick="verifyPwd()">Entrar</button>
        </div>
        <div class="auth-err" id="authErr"></div>
      </div>
      <div id="dataSection" style="display:none">
        <div class="stats-row">
          <div class="stat-box"><div class="n" id="statTotal">0</div><div class="l">Respostas</div></div>
          <div class="stat-box"><div class="n" id="statLast" style="font-size:0.8rem;padding-top:6px">—</div><div class="l">Última</div></div>
        </div>
        <div class="resp-scroll" id="respList"></div>
        <div class="admin-btns">
          <button class="btn-red" onclick="clearData()">🗑 Limpar dados</button>
          <button class="btn-out" onclick="logout()">← Sair</button>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
const SK = 'melhoria_em_foco_db';
const PWD = 'Melhoria@Foco2025';
let step = 1, authed = false;
const TOTAL = 5;

// Slider
const sl = document.getElementById('praticidade');
const sv = document.getElementById('sliderVal');
function updSlider() {
  const v = sl.value, p = (v/10)*100;
  sv.textContent = v + '/10';
  sl.style.backgroundSize = p + '% 100%';
}
sl.addEventListener('input', updSlider);
updSlider();

// Chips
document.querySelectorAll('.chip').forEach(c => {
  const inp = c.querySelector('input');
  inp.addEventListener('change', () => {
    if (inp.type === 'radio') {
      document.querySelectorAll(`input[name="${inp.name}"]`).forEach(r =>
        r.closest('.chip').classList.toggle('selected', r.checked));
    } else {
      c.classList.toggle('selected', inp.checked);
    }
    updCounters();
  });
});

function updCounters() {
  const d = document.querySelectorAll('#dificuldadesGroup input:checked').length;
  const dc = document.getElementById('dificuldadesCounter');
  dc.textContent = d ? d + ' selecionado' + (d > 1 ? 's' : '') : 'Selecione ao menos uma opção';
  dc.className = 'counter-tag' + (d ? ' active' : '');

  const t = document.querySelectorAll('#topicosGroup input:checked').length;
  const tc = document.getElementById('topicosCounter');
  tc.textContent = t ? t + ' selecionado' + (t > 1 ? 's' : '') : 'Selecione ao menos um tópico';
  tc.className = 'counter-tag' + (t ? ' active' : '');
}

function showStep(n) {
  for (let i = 1; i <= TOTAL; i++) {
    const el = document.getElementById('step' + i);
    if (el) el.classList.remove('active');
  }
  document.getElementById('step' + n).classList.add('active');
  document.getElementById('stepNum').innerHTML = String(n).padStart(2,'0') + '<span>/0' + TOTAL + '</span>';
  document.getElementById('progressFill').style.width = (n / TOTAL * 100) + '%';
}

function validate(s) {
  if (s === 1) {
    if (!document.getElementById('nome').value.trim()) { alert('Informe seu nome.'); return false; }
    const e = document.getElementById('email').value.trim();
    if (!e || !e.includes('@')) { alert('Informe um e-mail válido.'); return false; }
    if (!document.getElementById('whatsapp').value.trim()) { alert('Informe seu WhatsApp.'); return false; }
  }
  if (s === 2) {
    if (!document.getElementById('formacao').value) { alert('Selecione sua área de formação.'); return false; }
    if (!document.getElementById('experiencia').value) { alert('Selecione seu tempo no mercado.'); return false; }
  }
  if (s === 3 && !document.querySelectorAll('#dificuldadesGroup input:checked').length) {
    alert('Selecione ao menos uma dificuldade.'); return false;
  }
  if (s === 4) {
    if (!document.querySelector('input[name="interesse"]:checked')) { alert('Selecione seu nível de interesse.'); return false; }
    if (!document.querySelectorAll('#topicosGroup input:checked').length) { alert('Selecione ao menos um tópico.'); return false; }
  }
  return true;
}

function changeStep(dir) {
  if (dir === 1 && !validate(step)) return;
  const n = step + dir;
  if (n >= 1 && n <= TOTAL) { step = n; showStep(step); }
}

function getAll() { try { return JSON.parse(localStorage.getItem(SK) || '[]'); } catch { return []; } }
function saveResp(d) {
  const all = getAll();
  d.id = Date.now(); d.timestamp = new Date().toISOString();
  all.push(d);
  localStorage.setItem(SK, JSON.stringify(all));
}

// Função de envio de email CORRIGIDA com tratamento de erro adequado
async function sendEmail(d) {
  console.log('📧 Iniciando envio de email para melhoriaemfoco@gmail.com');
  
  // Criar objeto com os dados formatados
  const emailData = {
    nome: d.nome,
    email: d.email,
    whatsapp: d.whatsapp,
    formacao: d.formacao,
    experiencia: d.experiencia,
    interesse: d.interesse,
    dificuldades: d.dificuldades.join(', '),
    topicos: d.topicos.join(', '),
    praticidade: d.praticidade,
    sugestao: d.sugestao,
    data_hora: new Date().toLocaleString('pt-BR')
  };
  
  // Construir corpo do email formatado
  const emailBody = `
🔔 NOVA PESQUISA - Melhoria em Foco

━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

👤 NOME: ${emailData.nome}
📧 E-MAIL: ${emailData.email}
📱 WHATSAPP: ${emailData.whatsapp}

━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

🎓 FORMAÇÃO: ${emailData.formacao}
⏳ EXPERIÊNCIA: ${emailData.experiencia}

━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

📈 INTERESSE EM TREINAMENTO: ${emailData.interesse}

⚠️ DIFICULDADES:
${emailData.dificuldades.split(', ').map(d => `  • ${d}`).join('\n')}

🧠 TÓPICOS DE INTERESSE:
${emailData.topicos.split(', ').map(t => `  • ${t}`).join('\n')}

⚙️ IMPORTÂNCIA DA PRÁTICA: ${emailData.praticidade}

━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

💬 SUGESTÃO/CONTRIBUIÇÃO:
${emailData.sugestao || 'Nenhuma sugestão fornecida'}

━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

📅 DATA/HORA: ${emailData.data_hora}

🌿 Melhoria em Foco - Pesquisa de Treinamento
  `;
  
  // Opção 1: Usar FormSubmit com fallback
  const formData = new FormData();
  formData.append('_subject', `🔔 NOVA PESQUISA - ${d.nome}`);
  formData.append('_template', 'table');
  formData.append('_captcha', 'false');
  formData.append('_replyto', d.email);
  formData.append('message', emailBody);
  
  // Adicionar cada campo individualmente para melhor visualização
  Object.entries({
    'Nome Completo': d.nome,
    'E-mail': d.email,
    'WhatsApp': d.whatsapp,
    'Formação': d.formacao,
    'Experiência': d.experiencia,
    'Interesse em Treinamento': d.interesse,
    'Dificuldades': d.dificuldades.join(', '),
    'Tópicos de Interesse': d.topicos.join(', '),
    'Importância da Prática': d.praticidade,
    'Sugestão': d.sugestao || '—',
    'Data/Hora': new Date().toLocaleString('pt-BR')
  }).forEach(([k, v]) => formData.append(k, v));
  
  try {
    // Tentativa 1: FormSubmit
    const response = await fetch('https://formsubmit.co/ajax/melhoriaemfoco@gmail.com', {
      method: 'POST',
      body: formData
    });
    
    if (response.ok) {
      console.log('✅ Email enviado com sucesso via FormSubmit!');
      return true;
    } else {
      throw new Error('FormSubmit retornou erro: ' + response.status);
    }
  } catch (error) {
    console.error('❌ Erro no envio via FormSubmit:', error);
    
    // Tentativa 2: Mailto como fallback (abre cliente de email)
    try {
      const subject = encodeURIComponent(`🔔 NOVA PESQUISA - ${d.nome}`);
      const body = encodeURIComponent(emailBody);
      const mailtoLink = `mailto:melhoriaemfoco@gmail.com?subject=${subject}&body=${body}`;
      
      // Abrir em nova aba (silenciosamente)
      const mailWindow = window.open(mailtoLink, '_blank');
      setTimeout(() => {
        if (mailWindow) mailWindow.close();
      }, 500);
      
      console.log('📧 Fallback: Cliente de email aberto');
      return true;
    } catch (mailError) {
      console.error('❌ Falha completa no envio de email:', mailError);
      return false;
    }
  }
}

async function submitForm() {
  // Mostrar indicador de carregamento
  const sendBtn = document.querySelector('.btn-send');
  const originalText = sendBtn.innerHTML;
  sendBtn.innerHTML = '⏳ Enviando...';
  sendBtn.disabled = true;
  
  const dados = {
    nome: document.getElementById('nome').value.trim(),
    email: document.getElementById('email').value.trim(),
    whatsapp: document.getElementById('whatsapp').value.trim(),
    formacao: document.getElementById('formacao').value,
    experiencia: document.getElementById('experiencia').value,
    interesse: document.querySelector('input[name="interesse"]:checked')?.value,
    dificuldades: Array.from(document.querySelectorAll('#dificuldadesGroup input:checked')).map(c=>c.value),
    topicos: Array.from(document.querySelectorAll('#topicosGroup input:checked')).map(c=>c.value),
    praticidade: sl.value + '/10',
    sugestao: document.getElementById('sugestao').value.trim() || '—'
  };
  
  // Salvar no banco local
  saveResp(dados);
  
  // Enviar email com tentativas
  const emailSent = await sendEmail(dados);
  
  // Atualizar interface
  for (let i = 1; i <= TOTAL; i++) {
    const el = document.getElementById('step' + i);
    if (el) el.classList.remove('active');
  }
  document.getElementById('progressFill').style.width = '100%';
  document.getElementById('stepNum').innerHTML = '✓<span> feito</span>';
  document.getElementById('successName').textContent = dados.nome + '!';
  
  const emailStatusDiv = document.getElementById('emailStatus');
  if (emailSent) {
    emailStatusDiv.textContent = '✓ Email enviado com sucesso';
    emailStatusDiv.className = 's-pill ok';
  } else {
    emailStatusDiv.textContent = '⚠ Email salvo localmente (enviar depois)';
    emailStatusDiv.className = 's-pill';
  }
  
  document.getElementById('totalCount2').textContent = '📊 ' + getAll().length + ' respostas coletadas';
  document.getElementById('successScreen').classList.add('active');
  
  // Restaurar botão
  sendBtn.innerHTML = originalText;
  sendBtn.disabled = false;
  
  // Registrar no console para debug
  console.log('📊 Resposta salva. Total:', getAll().length);
  console.log('📧 Status do email:', emailSent ? 'ENVIADO' : 'FALHA - dados salvos localmente');
}

function openAdmin() { document.getElementById('overlay').classList.add('open'); }
function closeAdmin() { document.getElementById('overlay').classList.remove('open'); }
function overlayClick(e) { if (e.target === document.getElementById('overlay')) closeAdmin(); }

function verifyPwd() {
  if (document.getElementById('adminPwd').value === PWD) {
    authed = true;
    document.getElementById('authSection').style.display = 'none';
    document.getElementById('dataSection').style.display = 'block';
    refreshAdmin();
  } else {
    document.getElementById('authErr').textContent = '❌ Senha incorreta';
  }
}

function refreshAdmin() {
  const all = getAll();
  document.getElementById('statTotal').textContent = all.length;
  if (all.length) {
    document.getElementById('statLast').textContent =
      new Date(all[all.length-1].timestamp).toLocaleDateString('pt-BR');
  }
  const list = document.getElementById('respList');
  list.innerHTML = !all.length
    ? '<div class="resp-entry">Nenhuma resposta ainda</div>'
    : [...all].reverse().map(r => `<div class="resp-entry"><strong>${esc(r.nome)}</strong><br>${esc(r.email)} · ${esc(r.whatsapp)}<br>Interesse: ${esc(r.interesse)} · ${esc(r.formacao)}</div>`).join('');
}

function esc(t) { if(!t)return''; const d=document.createElement('div');d.textContent=t;return d.innerHTML; }

function clearData() {
  if (!authed) return;
  if (confirm('Remover TODAS as respostas?')) { localStorage.removeItem(SK); refreshAdmin(); }
}

function logout() {
  authed = false;
  document.getElementById('authSection').style.display = 'block';
  document.getElementById('dataSection').style.display = 'none';
  document.getElementById('adminPwd').value = '';
  document.getElementById('authErr').textContent = '';
}

showStep(1);
</script>
</body>
</html>